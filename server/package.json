{
  "name": "meety-backend",
  "version": "1.0.0",
  "description": "Production-ready Express 5 backend starter",
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "db:check": "drizzle-kit check --config=drizzle.config.js",
    "db:generate": "drizzle-kit generate --config=drizzle.config.js",
    "db:migrate": "drizzle-kit migrate --config=drizzle.config.js",
    "db:push": "drizzle-kit push --config=drizzle.config.js",
    "db:studio": "drizzle-kit studio --config=drizzle.config.js",
    "dev": "nodemon src/server.js",
    "start": "node src/server.js"
  },
  "dependencies": {
    "@clerk/express": "^2.0.4",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "http-status-codes": "^2.3.0",
    "morgan": "^1.10.1",
    "pg": "^8.20.0",
    "socket.io": "^4.8.3",
    "svix": "^1.88.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.9",
    "nodemon": "^3.1.14"
  }
}
